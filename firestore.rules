rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }
    function me() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }
    function isMember(klasseId) {
      return isAuth() && klasseId in me().get('klasseIds', []);
    }
    function isKlassenAdmin(klasseId) {
      return isMember(klasseId) &&
        uid() in get(/databases/$(database)/documents/klassen/$(klasseId)).data.adminIds;
    }
    // Kurs-Admin = Ersteller des Kurses
    function isKursAdmin(klasseId, kursId) {
      return isMember(klasseId) &&
        get(/databases/$(database)/documents/klassen/$(klasseId)/kurse/$(kursId)).data.erstellerId == uid();
    }

    match /users/{userId} {
      // Lesen: sich selbst oder wer mindestens eine Klasse mit einem teilt (Klassenkameraden)
      allow read: if isAuth() && (
        uid() == userId ||
        resource.data.get('klasseIds', []).hasAny(me().get('klasseIds', []))
      );
      allow create: if isAuth() && uid() == userId;
      // Eigenes Doc bearbeiten. Multi-Klassen:
      //  - activeKlasseId muss null oder eine der eigenen Klassen sein
      //  - beim HINZUFÜGEN einer Klasse (klasseIds wächst) darf nur genau die neue aktive Klasse
      //    dazukommen und man darf dort nicht gesperrt sein (Ban-Schutz). Entfernen/Umsortieren frei.
      allow update: if isAuth() && uid() == userId
        && ( request.resource.data.get('activeKlasseId', null) == null ||
             request.resource.data.activeKlasseId in request.resource.data.get('klasseIds', []) )
        && (
          request.resource.data.get('klasseIds', []).toSet()
            .difference(resource.data.get('klasseIds', []).toSet()).size() == 0 ||
          ( request.resource.data.get('klasseIds', []).toSet()
              .difference(resource.data.get('klasseIds', []).toSet())
              .hasOnly([request.resource.data.activeKlasseId]) &&
            request.resource.data.get('klasseIds', []).toSet()
              .difference(resource.data.get('klasseIds', []).toSet()).size() == 1 &&
            !(uid() in get(/databases/$(database)/documents/klassen/$(request.resource.data.activeKlasseId)).data.get('bannedIds', [])) )
        );
      allow delete: if false;
    }

    match /klassen/{klasseId} {
      // Lesen für alle eingeloggten User (nötig für Beitritt per Code-Query)
      allow read: if isAuth();
      allow create: if isAuth() &&
        request.resource.data.adminIds is list &&
        uid() in request.resource.data.adminIds;
      allow update: if isAuth() && uid() in resource.data.adminIds;
      allow delete: if isAuth() && uid() in resource.data.adminIds;

      match /kurse/{kursId} {
        allow read: if isAuth();
        // Jedes Klassenmitglied darf Kurse erstellen (wird Kurs-Admin, einziges Mitglied)
        allow create: if isMember(klasseId) &&
          request.resource.data.erstellerId == uid() &&
          request.resource.data.memberIds == [uid()];
        // Bearbeiten: Klassen-Admin, Kurs-Ersteller – oder jedes Mitglied, aber
        // nur das memberIds-Feld (Selbst-Beitritt/-Austritt über Kurswahl)
        allow update: if isMember(klasseId) && (
          isKlassenAdmin(klasseId) ||
          resource.data.erstellerId == uid() ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
        );
        allow delete: if isKlassenAdmin(klasseId) ||
          (isMember(klasseId) && resource.data.erstellerId == uid());

        match /materialien/{matId} {
          allow read: if isMember(klasseId);
          allow create: if isMember(klasseId) &&
            request.resource.data.autorId == uid();
          // Likes darf jedes Mitglied togglen, alles andere nur Autor/Admin
          allow update: if isMember(klasseId) && (
            isKlassenAdmin(klasseId) ||
            resource.data.autorId == uid() ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
          );
          // Löschen: Autor, Klassen-Admin oder Kurs-Admin (Rechte-Matrix + Lösch-Kaskade)
          allow delete: if isMember(klasseId) && (
            isKlassenAdmin(klasseId) ||
            isKursAdmin(klasseId, kursId) ||
            resource.data.autorId == uid()
          );
        }

        match /hausaufgaben/{haId} {
          allow read: if isMember(klasseId);
          allow create: if isMember(klasseId) &&
            request.resource.data.autorId == uid();
          // doneBy/hiddenBy darf jedes Mitglied ändern, alles andere nur Autor/Admin
          allow update: if isMember(klasseId) && (
            isKlassenAdmin(klasseId) ||
            resource.data.autorId == uid() ||
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['doneBy', 'hiddenBy'])
          );
          // Kurs-Admin nur für die Lösch-Kaskade beim Kurs-Löschen
          allow delete: if isMember(klasseId) && (
            isKlassenAdmin(klasseId) ||
            isKursAdmin(klasseId, kursId) ||
            resource.data.autorId == uid()
          );
        }

        match /pruefungen/{prId} {
          allow read: if isMember(klasseId);
          allow create: if isMember(klasseId) &&
            request.resource.data.autorId == uid();
          allow update: if isMember(klasseId) && (
            isKlassenAdmin(klasseId) || resource.data.autorId == uid()
          );
          allow delete: if isMember(klasseId) && (
            isKlassenAdmin(klasseId) ||
            isKursAdmin(klasseId, kursId) ||
            resource.data.autorId == uid()
          );
        }

        match /chat/{msgId} {
          allow read: if isMember(klasseId);
          allow create: if isMember(klasseId) &&
            request.resource.data.autorId == uid();
          // Bearbeiten (Autor) + Löschen als Tombstone (Autor/Kurs-/Klassen-Admin)
          allow update: if isMember(klasseId) && (
            // Autor bearbeitet eigenen Text (nicht auf bereits gelöschten Nachrichten)
            ( resource.data.autorId == uid() &&
              resource.data.get('deleted', false) == false &&
              request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['text', 'editedAt']) ) ||
            // Tombstone-Löschen: Autor ODER Kurs-/Klassen-Admin; setzt deleted + leert text
            ( (isKlassenAdmin(klasseId) || isKursAdmin(klasseId, kursId) ||
               resource.data.autorId == uid()) &&
              request.resource.data.deleted == true &&
              request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['deleted', 'text']) )
          );
          // Hard-delete: Klassen-/Kurs-Admin – nur für die Lösch-Kaskade (Kurs/Klasse löschen)
          allow delete: if isKlassenAdmin(klasseId) || isKursAdmin(klasseId, kursId);
        }
      }

      // Sammlungen: persönliche/geteilte Material-Zusammenstellungen (memberIds-Muster).
      // [ownerId] = privat; weitere Mitglieder = geteilt/kollaborativ.
      match /sammlungen/{sammlungId} {
        // Sammlungs-Mitglieder lesen ihre Sammlung; Klassen-Admin darf zusätzlich lesen –
        // nötig, damit die Lösch-Kaskade (deleteKlasse) alle Sammlungen auflisten kann.
        // Kein UI-Privacy-Leak: die Bibliothek fragt nur where memberIds array-contains uid ab.
        allow read: if isMember(klasseId) &&
          (uid() in resource.data.memberIds || isKlassenAdmin(klasseId));
        allow create: if isMember(klasseId) &&
          request.resource.data.ownerId == uid() &&
          request.resource.data.memberIds == [uid()];
        // Mitglieder dürfen items/memberIds ändern (Kollaboration + Selbst-Verlassen);
        // Umbenennen/Freigabe-Verwaltung bleibt dem Owner vorbehalten.
        allow update: if isMember(klasseId) && (
          resource.data.ownerId == uid() ||
          (uid() in resource.data.memberIds &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['items', 'memberIds']))
        );
        // Owner löscht die eigene Sammlung; Klassen-Admin zusätzlich für die Lösch-Kaskade.
        allow delete: if isMember(klasseId) && (
          resource.data.ownerId == uid() || isKlassenAdmin(klasseId)
        );
      }
    }
  }
}
